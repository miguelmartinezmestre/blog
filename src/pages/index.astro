---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Bienvenido a mi blog!</h1>
			<p>
				Este es un blog personal donde comparto mis proyectos y conocimientos sobre desarrollo.
			</p>
			<p>Algunos de los temas que podrás encontrar son:</p>
			<ul>
				<li>Frontend</li>
				<li>Backend</li>
				<li>Desarrollo movil</li>
				<li>Desarrollo de software</li>
			</ul>

			<a href="https://github.com/withastro/astro/tree/main/examples/blog">Creado utilizando este ejemplo de Astro</a>
		</main>
		<Footer />
	</body>
</html>
